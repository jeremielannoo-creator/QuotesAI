# =============================================
# QUOTESAI - Configuration des clés API
# Renommer ce fichier en .env et remplir les valeurs
# =============================================

# --- Google Gemini ---
GEMINI_API_KEY=AIza...

# --- Pexels (vidéos background) ---
PEXELS_API_KEY=...

# --- Cloudinary (hébergement temporaire pour Instagram) ---
# Créer un compte gratuit sur cloudinary.com
CLOUDINARY_CLOUD_NAME=mon_cloud
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# --- Instagram Graph API ---
# Compte Instagram Creator/Business requis
# Token généré via https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=EAABsb...
INSTAGRAM_USER_ID=17841...

# --- TikTok Content Posting API ---
# Accès via https://developers.tiktok.com/
TIKTOK_ACCESS_TOKEN=act....
TIKTOK_OPEN_ID=...
